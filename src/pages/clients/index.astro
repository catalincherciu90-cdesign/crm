---
import { desc, or, like, and, eq, sql, type SQL } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/db';
import { clients } from '@/db/schema';

export const prerender = false;

const PER_PAGE = 50;
const db = getDb(Astro.locals.runtime.env.DB);

const q = (Astro.url.searchParams.get('q') || '').trim();
const activeParam = Astro.url.searchParams.get('active'); // '1' | '0' | null
const agentParam = Number(Astro.url.searchParams.get('agent')) || 0;
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);

const conds: SQL[] = [];
if (q) {
  const pat = `%${q}%`;
  conds.push(
    or(
      like(clients.name, pat),
      like(clients.company, pat),
      like(clients.email, pat),
      like(clients.phone, pat),
      like(clients.taxId, pat),
    )!,
  );
}
if (activeParam === '1') conds.push(eq(clients.active, true));
if (activeParam === '0') conds.push(eq(clients.active, false));
if (agentParam) conds.push(eq(clients.agentId, agentParam));
const where = conds.length ? and(...conds) : undefined;

// Totaluri globale (neafectate de filtre)
const [counts] = await db
  .select({
    total: sql<number>`count(*)`,
    active: sql<number>`sum(case when active = 1 then 1 else 0 end)`,
    inactive: sql<number>`sum(case when active = 0 then 1 else 0 end)`,
  })
  .from(clients);

const [{ total }] = await db.select({ total: sql<number>`count(*)` }).from(clients).where(where);
const rows = await db
  .select()
  .from(clients)
  .where(where)
  .orderBy(desc(clients.id))
  .limit(PER_PAGE)
  .offset((page - 1) * PER_PAGE);

const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
const buildUrl = (params: Record<string, string | number | undefined>) => {
  const merged = { q, active: activeParam ?? undefined, agent: agentParam || undefined, ...params };
  const sp = new URLSearchParams();
  for (const [k, v] of Object.entries(merged)) {
    if (v !== undefined && v !== '' && v !== null && !(k === 'page' && Number(v) === 1)) sp.set(k, String(v));
  }
  const s = sp.toString();
  return '/clients' + (s ? `?${s}` : '');
};
const pageUrl = (p: number) => buildUrl({ page: p });
const filters = [
  { label: 'Toți', val: undefined, on: !activeParam, n: counts.total },
  { label: 'Activi', val: '1', on: activeParam === '1', n: counts.active },
  { label: 'Inactivi', val: '0', on: activeParam === '0', n: counts.inactive },
];
const filtered = Boolean(q || activeParam || agentParam);
const deletedN = Number(Astro.url.searchParams.get('deleted')) || 0;
const skippedN = Number(Astro.url.searchParams.get('skipped')) || 0;
---

<Layout title="Clienti">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Clienți</h1>
      <p class="text-sm text-slate-500">
        <span class="font-semibold text-slate-700">{counts.total}</span> clienți în total
        {filtered && <> · {total} {q ? `pentru „${q}”` : ''} afișați</>}
      </p>
    </div>
    <div class="flex gap-2">
      <a href="/clients/import" class="rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-100">↑ Import Excel</a>
      <a href="/clients/new" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">+ Client nou</a>
    </div>
  </div>

  <form method="GET" action="/clients" class="mb-3 flex gap-2">
    {activeParam && <input type="hidden" name="active" value={activeParam} />}
    <input type="search" name="q" value={q} placeholder="Caută după nume, firmă, email, telefon, CIF..."
      class="w-full max-w-md rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" />
    <button class="rounded-lg bg-slate-800 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-900">Caută</button>
    {(q || activeParam) && <a href="/clients" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">Resetează</a>}
  </form>

  <div class="mb-4 flex flex-wrap items-center gap-2">
    {filters.map((f) => (
      <a href={buildUrl({ active: f.val, page: 1 })} class={`rounded-full px-3 py-1 text-sm font-medium transition ${f.on ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-indigo-300'}`}>
        {f.label} ({f.n})
      </a>
    ))}
  </div>

  {(deletedN > 0 || skippedN > 0) && (
    <div class="mb-4 rounded-lg bg-green-50 px-4 py-3 text-sm text-green-700">
      {deletedN} clienți șterși{skippedN > 0 ? ` · ${skippedN} săriți (au oferte)` : ''}.
    </div>
  )}

  {rows.length > 0 && (
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <button form="bulkForm" type="submit" class="rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-100">🗑 Șterge selectații</button>
      <form method="POST" action="/api/clients/bulk-delete" onsubmit={`return confirm('Ștergi TOȚI cei ${total} clienți din filtrul curent? Cei cu oferte sunt săriți. Acțiunea nu poate fi anulată.')`}>
        <input type="hidden" name="all" value="1" />
        {q && <input type="hidden" name="q" value={q} />}
        {activeParam && <input type="hidden" name="active" value={activeParam} />}
        {agentParam > 0 && <input type="hidden" name="agent" value={agentParam} />}
        <button type="submit" class="rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50">Șterge toți cei {total} {filtered ? '(din filtru)' : ''}</button>
      </form>
    </div>
  )}

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    {rows.length === 0 ? (
      <p class="p-8 text-center text-sm text-slate-400">{filtered ? 'Niciun client găsit.' : 'Niciun client. Adaugă primul client sau importă din Excel.'}</p>
    ) : (
      <form id="bulkForm" method="POST" action="/api/clients/bulk-delete">
      <table class="w-full text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3 w-8"><input type="checkbox" id="selectAll" /></th>
            <th class="px-4 py-3">Nume</th>
            <th class="px-4 py-3">Firmă / CUI</th>
            <th class="px-4 py-3">Contact</th>
            <th class="px-4 py-3">Listă preț</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rows.map((c) => (
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3"><input type="checkbox" name="ids" value={c.id} class="rowbox" /></td>
              <td class="px-4 py-3 font-medium text-slate-900"><a href={`/clients/${c.id}`} class="hover:text-indigo-600">{c.name}</a></td>
              <td class="px-4 py-3 text-slate-600">
                {c.company ?? '—'}
                {c.taxId && <span class="block text-xs text-slate-400">{c.taxId}</span>}
              </td>
              <td class="px-4 py-3 text-slate-600">
                {c.email ?? '—'}
                {c.phone && <span class="block text-xs text-slate-400">{c.phone}</span>}
              </td>
              <td class="px-4 py-3 text-slate-600">{c.priceList ? c.priceList.replace('PRET_', 'Preț ') : '—'}</td>
              <td class="px-4 py-3">
                {c.active
                  ? <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-[11px] font-medium text-green-700">Activ</span>
                  : <span class="inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-500">Inactiv</span>}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/clients/${c.id}`} class="text-indigo-600 hover:underline">Editează</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      </form>
    )}
  </div>

  {totalPages > 1 && (
    <div class="mt-4 flex items-center justify-between text-sm">
      <span class="text-slate-500">Pagina {page} din {totalPages}</span>
      <div class="flex gap-2">
        {page > 1 && <a href={pageUrl(page - 1)} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">← Anterioară</a>}
        {page < totalPages && <a href={pageUrl(page + 1)} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">Următoare →</a>}
      </div>
    </div>
  )}
</Layout>

<script is:inline>
  (function () {
    const selectAll = document.getElementById('selectAll');
    const boxes = () => Array.prototype.slice.call(document.querySelectorAll('.rowbox'));
    if (selectAll) selectAll.addEventListener('change', () => boxes().forEach((b) => (b.checked = selectAll.checked)));
    const form = document.getElementById('bulkForm');
    if (form)
      form.addEventListener('submit', (e) => {
        const n = boxes().filter((b) => b.checked).length;
        if (n === 0) {
          e.preventDefault();
          alert('Selectează cel puțin un client (bifează căsuțele).');
          return;
        }
        if (!confirm('Ștergi ' + n + ' clienți selectați? Cei cu oferte sunt săriți. Acțiunea nu poate fi anulată.')) e.preventDefault();
      });
  })();
</script>
