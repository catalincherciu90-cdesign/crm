---
import '@/styles/global.css';

interface Props {
  title?: string;
}
const { title = 'CRM' } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Dashboard', icon: '📊' },
  { href: '/offers', label: 'Oferte', icon: '📄' },
  { href: '/products', label: 'Produse & Stocuri', icon: '📦' },
  { href: '/clients', label: 'Clienti', icon: '👥' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · CRM</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="no-print hidden w-60 shrink-0 flex-col border-r border-slate-200 bg-white sm:flex">
        <div class="border-b border-slate-200 px-6 py-5">
          <a href="/" class="text-lg font-bold text-slate-900">CRM<span class="text-indigo-600">.</span></a>
          <p class="mt-0.5 text-xs text-slate-400">Oferte &amp; Stocuri</p>
        </div>
        <nav class="flex-1 space-y-1 p-3">
          {nav.map((item) => (
            <a
              href={item.href}
              class={`flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition ${
                isActive(item.href)
                  ? 'bg-indigo-50 text-indigo-700'
                  : 'text-slate-600 hover:bg-slate-100'
              }`}
            >
              <span>{item.icon}</span>
              {item.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-slate-200 p-4 text-xs text-slate-400">
          Faza 2: product feed
        </div>
      </aside>

      <!-- Main -->
      <div class="flex flex-1 flex-col">
        <!-- Mobile nav -->
        <header class="no-print flex items-center gap-4 overflow-x-auto border-b border-slate-200 bg-white px-4 py-3 sm:hidden">
          <a href="/" class="text-base font-bold text-slate-900">CRM<span class="text-indigo-600">.</span></a>
          {nav.map((item) => (
            <a href={item.href} class={`whitespace-nowrap text-sm ${isActive(item.href) ? 'text-indigo-700 font-semibold' : 'text-slate-500'}`}>
              {item.label}
            </a>
          ))}
        </header>

        <main class="flex-1 p-4 sm:p-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
