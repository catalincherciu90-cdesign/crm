---
import { asc } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import ClientForm from '@/components/ClientForm.astro';
import { getDb } from '@/db';
import { agents } from '@/db/schema';

export const prerender = false;

const db = getDb(Astro.locals.runtime.env.DB);
const agentList =
  Astro.locals.user?.role === 'admin' ? await db.select().from(agents).orderBy(asc(agents.name)) : [];
---

<Layout title="Client nou">
  <div class="mx-auto max-w-2xl">
    <a href="/clients" class="text-sm text-indigo-600 hover:underline">← Clienți</a>
    <h1 class="mt-2 mb-6 text-2xl font-bold text-slate-900">Client nou</h1>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <ClientForm agents={agentList} />
    </div>
  </div>
</Layout>
