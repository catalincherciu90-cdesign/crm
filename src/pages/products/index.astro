---
import { asc, and, or, like, sql, type SQL } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/db';
import { products } from '@/db/schema';
import { formatMoney, formatQty } from '@/lib/money';
import { proxied } from '@/lib/img';

const isAdmin = Astro.locals.user?.role === 'admin';

export const prerender = false;

const PER_PAGE = 50;
const db = getDb(Astro.locals.runtime.env.DB);

const url = Astro.url;
const cat = (url.searchParams.get('cat') || '').trim();
const q = (url.searchParams.get('q') || '').trim();
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);

// Filtre
const filters: SQL[] = [];
if (cat) filters.push(like(products.category, `%${cat}%`));
if (q) {
  const pat = `%${q}%`;
  filters.push(or(like(products.name, pat), like(products.sku, pat), like(products.brand, pat))!);
}
const where = filters.length ? and(...filters) : undefined;

// Categorii principale (top-level, inainte de primul '/') cu numar de produse
const catRows = (await db.all(sql`
  SELECT CASE WHEN instr(category,'/') > 0 THEN substr(category, 1, instr(category,'/') - 1) ELSE category END AS top,
         count(*) AS n
  FROM products
  WHERE category IS NOT NULL AND category != ''
  GROUP BY top ORDER BY n DESC
`)) as { top: string; n: number }[];

// Total pentru paginare + randurile paginii
const [{ total }] = await db.select({ total: sql<number>`count(*)` }).from(products).where(where);
const rows = await db
  .select()
  .from(products)
  .where(where)
  .orderBy(asc(products.name))
  .limit(PER_PAGE)
  .offset((page - 1) * PER_PAGE);

const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));

// Fallback cand poza (de pe CDN extern) nu se incarca -> iconita placeholder, fara "broken image"
const IMG_FALLBACK =
  "this.onerror=null;this.src=\"data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23cbd5e1' stroke-width='1.5'%3E%3Crect x='3' y='3' width='18' height='18' rx='2'/%3E%3Ccircle cx='8.5' cy='8.5' r='1.5'/%3E%3Cpath d='m21 15-5-5L5 21'/%3E%3C/svg%3E\";this.classList.add('opacity-50','p-1');";

function stockState(p: (typeof rows)[number]) {
  if (p.stockQty <= 0) return { label: 'Epuizat', cls: 'bg-red-100 text-red-700' };
  if (p.lowStockThreshold > 0 && p.stockQty <= p.lowStockThreshold)
    return { label: 'Stoc scăzut', cls: 'bg-amber-100 text-amber-700' };
  return { label: 'În stoc', cls: 'bg-green-100 text-green-700' };
}

// Construieste URL pastrand filtrele
function buildUrl(params: Record<string, string | number | undefined>) {
  const sp = new URLSearchParams();
  const merged = { cat, q, ...params };
  for (const [k, v] of Object.entries(merged)) {
    if (v !== undefined && v !== '' && !(k === 'page' && Number(v) === 1)) sp.set(k, String(v));
  }
  const s = sp.toString();
  return '/products' + (s ? `?${s}` : '');
}
---

<Layout title="Produse & Stocuri">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Produse &amp; Stocuri</h1>
      <p class="text-sm text-slate-500">{total} produse{cat ? ` în „${cat}”` : ''}{q ? ` pentru „${q}”` : ''}.</p>
    </div>
    {isAdmin && (
      <div class="flex gap-2">
        <a href="/products/import" class="rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-100">↓ Import feed</a>
        <a href="/products/new" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">+ Produs nou</a>
      </div>
    )}
  </div>

  <!-- Cautare -->
  <form method="GET" action="/products" class="mb-4 flex gap-2">
    {cat && <input type="hidden" name="cat" value={cat} />}
    <input
      type="search" name="q" value={q} placeholder="Caută după nume, SKU sau brand..."
      class="w-full max-w-md rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
    />
    <button class="rounded-lg bg-slate-800 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-900">Caută</button>
    {(q || cat) && <a href="/products" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-600 hover:bg-slate-50">Resetează</a>}
  </form>

  <!-- Categorii -->
  {catRows.length > 0 && (
    <div class="mb-5 flex flex-wrap gap-2">
      <a href={buildUrl({ cat: '', page: 1 })} class={`rounded-full px-3 py-1 text-sm font-medium transition ${!cat ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-indigo-300'}`}>
        Toate ({total >= 0 ? catRows.reduce((s, c) => s + c.n, 0) : 0})
      </a>
      {catRows.map((c) => (
        <a href={buildUrl({ cat: c.top, page: 1 })} class={`rounded-full px-3 py-1 text-sm font-medium transition ${cat === c.top ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-indigo-300'}`}>
          {c.top} ({c.n})
        </a>
      ))}
    </div>
  )}

  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
    {rows.length === 0 ? (
      <p class="p-8 text-center text-sm text-slate-400">Niciun produs găsit. {cat || q ? 'Încearcă alt filtru.' : 'Adaugă primul produs în catalog.'}</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">Produs</th>
            <th class="px-4 py-3">Categorie</th>
            <th class="px-4 py-3 text-right">Preț</th>
            <th class="px-4 py-3 text-right">Stoc</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rows.map((p) => {
            const st = stockState(p);
            return (
              <tr class="cursor-pointer hover:bg-slate-50" onclick={`location.href='/products/${p.id}'`}>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    {p.images ? (
                      <img src={proxied(p.images.split('#')[0])} alt={p.name} loading="lazy" onerror={IMG_FALLBACK} class="h-10 w-10 shrink-0 rounded border border-slate-200 object-contain bg-white" />
                    ) : (
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded border border-slate-100 bg-slate-50 text-slate-300">📦</div>
                    )}
                    <div>
                      <div class="font-medium text-slate-900">{p.name}</div>
                      <div class="text-xs text-slate-400">
                        {p.sku}{p.brand ? ` · ${p.brand}` : ''}
                        {p.files && <span class="ml-1 text-indigo-400">· 📄 fișă</span>}
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-slate-600">{p.category ?? '—'}</td>
                <td class="px-4 py-3 text-right font-medium text-slate-900">{formatMoney(p.price, p.currency)}</td>
                <td class="px-4 py-3 text-right text-slate-700">{formatQty(p.stockQty)} {p.unit}</td>
                <td class="px-4 py-3">
                  <span class={`inline-block rounded-full px-2 py-0.5 text-[11px] font-medium ${st.cls}`}>{st.label}</span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a href={`/products/${p.id}`} class="text-indigo-600 hover:underline">Detalii →</a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <!-- Paginare -->
  {totalPages > 1 && (
    <div class="mt-4 flex items-center justify-between text-sm">
      <span class="text-slate-500">Pagina {page} din {totalPages}</span>
      <div class="flex gap-2">
        {page > 1 && <a href={buildUrl({ page: page - 1 })} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">← Anterioară</a>}
        {page < totalPages && <a href={buildUrl({ page: page + 1 })} class="rounded-lg border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">Următoare →</a>}
      </div>
    </div>
  )}

  <p class="mt-4 text-xs text-slate-400">
    💡 Produsele se importă din feed (Import feed). Filtrează pe categorii sau caută după nume/SKU/brand.
  </p>
</Layout>
