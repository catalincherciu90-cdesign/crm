---
import '@/styles/global.css';
import { ensureAuthTables, countUsers } from '@/lib/auth';

export const prerender = false;

const d1 = Astro.locals.runtime.env.DB;
await ensureAuthTables(d1);
const isFirstRun = (await countUsers(d1)) === 0;
const error = Astro.url.searchParams.get('error');

const field =
  'mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500';
const label = 'block text-xs font-medium text-slate-600';
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isFirstRun ? 'Configurare cont' : 'Autentificare'} · CRM</title>
  </head>
  <body class="flex min-h-screen items-center justify-center bg-slate-100 p-4">
    <div class="w-full max-w-sm">
      <div class="mb-6 text-center">
        <div class="text-2xl font-bold text-slate-900">CRM<span class="text-indigo-600">.</span></div>
        <p class="mt-1 text-sm text-slate-500">Oferte &amp; Stocuri</p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        {error === 'invalid' && (
          <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">Email sau parolă greșite.</div>
        )}
        {error === 'exists' && (
          <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">Contul de administrator există deja — autentifică-te.</div>
        )}

        {isFirstRun ? (
          <>
            <h1 class="mb-1 text-lg font-bold text-slate-900">Bine ai venit! 👋</h1>
            <p class="mb-4 text-sm text-slate-500">Creează contul de <strong>administrator</strong> (prima configurare, o singură dată).</p>
            <form method="POST" action="/api/first-admin" class="space-y-3">
              <div>
                <label class={label} for="name">Nume</label>
                <input class={field} id="name" name="name" placeholder="Catalin" />
              </div>
              <div>
                <label class={label} for="email">Email *</label>
                <input class={field} id="email" name="email" type="email" required />
              </div>
              <div>
                <label class={label} for="password">Parolă * (min. 8 caractere)</label>
                <input class={field} id="password" name="password" type="password" minlength="8" required />
              </div>
              <button class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">
                Creează contul de admin
              </button>
            </form>
          </>
        ) : (
          <>
            <h1 class="mb-4 text-lg font-bold text-slate-900">Autentificare</h1>
            <form method="POST" action="/api/login" class="space-y-3">
              <div>
                <label class={label} for="email">Email</label>
                <input class={field} id="email" name="email" type="email" required autofocus />
              </div>
              <div>
                <label class={label} for="password">Parolă</label>
                <input class={field} id="password" name="password" type="password" required />
              </div>
              <button class="w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700">
                Intră în cont
              </button>
            </form>
          </>
        )}
      </div>
    </div>
  </body>
</html>
