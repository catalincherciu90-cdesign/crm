---
import Layout from '@/layouts/Layout.astro';
import ProductForm from '@/components/ProductForm.astro';
export const prerender = false;
---

<Layout title="Produs nou">
  <div class="mx-auto max-w-2xl">
    <a href="/products" class="text-sm text-indigo-600 hover:underline">← Produse</a>
    <h1 class="mt-2 mb-6 text-2xl font-bold text-slate-900">Produs nou</h1>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <ProductForm />
    </div>
  </div>
</Layout>
