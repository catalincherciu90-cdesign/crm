---
import { eq, asc } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/db';
import { offers, offerItems, clients } from '@/db/schema';
import { formatMoney, formatQty } from '@/lib/money';

export const prerender = false;

const id = Number(Astro.params.id);
const db = getDb(Astro.locals.runtime.env.DB);

const [offer] = await db.select().from(offers).where(eq(offers.id, id));
if (!offer) return Astro.redirect('/offers');

const [client] = await db.select().from(clients).where(eq(clients.id, offer.clientId));

// Agentul poate deschide doar ofertele clientilor lui
const user = Astro.locals.user;
if (user?.role !== 'admin' && client?.agentId !== (user?.agentId ?? -1)) return Astro.redirect('/offers');
const items = await db.select().from(offerItems).where(eq(offerItems.offerId, id)).orderBy(asc(offerItems.position));

const statusLabel: Record<string, string> = { draft: 'Ciornă', sent: 'Trimisă', accepted: 'Acceptată', rejected: 'Respinsă' };
const statusClass: Record<string, string> = {
  draft: 'bg-slate-100 text-slate-600', sent: 'bg-blue-100 text-blue-700',
  accepted: 'bg-green-100 text-green-700', rejected: 'bg-red-100 text-red-700',
};
const statusActions = [
  { s: 'sent', label: 'Marchează trimisă' },
  { s: 'accepted', label: 'Acceptată' },
  { s: 'rejected', label: 'Respinsă' },
  { s: 'draft', label: 'Înapoi la ciornă' },
];
---

<Layout title={offer.number}>
  <!-- Toolbar -->
  <div class="no-print mb-6 flex flex-wrap items-center justify-between gap-3">
    <a href="/offers" class="text-sm text-indigo-600 hover:underline">← Oferte</a>
    <div class="flex flex-wrap items-center gap-2">
      {statusActions.filter((a) => a.s !== offer.status).map((a) => (
        <form method="POST" action="/api/offer-status" class="inline">
          <input type="hidden" name="id" value={offer.id} />
          <input type="hidden" name="status" value={a.s} />
          <button class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50">{a.label}</button>
        </form>
      ))}
      <button onclick="window.print()" class="rounded-lg bg-slate-800 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-900">🖨️ Print / PDF</button>
    </div>
  </div>

  <!-- Document oferta -->
  <div class="print-container mx-auto max-w-3xl rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="flex items-start justify-between border-b border-slate-200 pb-6">
      <div>
        <div class="text-lg font-bold text-slate-900">Ofertă {offer.number}</div>
        <div class="mt-1 text-sm text-slate-500">Emisă: {offer.issueDate}{offer.validUntil ? ` · Valabilă până la: ${offer.validUntil}` : ''}</div>
      </div>
      <span class={`no-print rounded-full px-3 py-1 text-xs font-medium ${statusClass[offer.status]}`}>{statusLabel[offer.status]}</span>
    </div>

    <div class="mt-6">
      <div class="text-xs uppercase tracking-wide text-slate-400">Client</div>
      <div class="mt-1 font-semibold text-slate-900">{client?.name}</div>
      {client?.company && <div class="text-sm text-slate-600">{client.company}{client.taxId ? ` · ${client.taxId}` : ''}</div>}
      <div class="text-sm text-slate-500">
        {[client?.email, client?.phone, client?.address].filter(Boolean).join(' · ')}
      </div>
    </div>

    <table class="mt-6 w-full text-sm">
      <thead class="border-b border-slate-300 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="py-2">Descriere</th>
          <th class="py-2 text-right">Cant.</th>
          <th class="py-2 text-right">Preț unit.</th>
          <th class="py-2 text-right">Disc.</th>
          <th class="py-2 text-right">TVA</th>
          <th class="py-2 text-right">Net</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {items.map((it) => (
          <tr>
            <td class="py-2 pr-2 text-slate-800">{it.description}</td>
            <td class="py-2 text-right text-slate-600">{formatQty(it.qty)} {it.unit}</td>
            <td class="py-2 text-right text-slate-600">{formatMoney(it.unitPrice, offer.currency)}</td>
            <td class="py-2 text-right text-slate-600">{it.discountPct ? it.discountPct + '%' : '—'}</td>
            <td class="py-2 text-right text-slate-600">{it.vatRate}%</td>
            <td class="py-2 text-right font-medium text-slate-900">{formatMoney(it.lineTotal, offer.currency)}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="mt-6 flex justify-end">
      <dl class="w-64 space-y-1.5 text-sm">
        <div class="flex justify-between"><dt class="text-slate-500">Subtotal</dt><dd>{formatMoney(offer.subtotal, offer.currency)}</dd></div>
        {offer.discountTotal > 0 && (
          <div class="flex justify-between"><dt class="text-slate-500">Discount ofertă ({offer.discountPct}%)</dt><dd class="text-red-600">− {formatMoney(offer.discountTotal, offer.currency)}</dd></div>
        )}
        <div class="flex justify-between"><dt class="text-slate-500">TVA</dt><dd>{formatMoney(offer.vatTotal, offer.currency)}</dd></div>
        <div class="flex justify-between border-t border-slate-300 pt-1.5 text-base font-bold text-slate-900"><dt>Total</dt><dd>{formatMoney(offer.total, offer.currency)}</dd></div>
      </dl>
    </div>

    {offer.notes && (
      <div class="mt-8 border-t border-slate-200 pt-4 text-sm text-slate-600">
        <div class="text-xs uppercase tracking-wide text-slate-400">Note</div>
        <p class="mt-1 whitespace-pre-line">{offer.notes}</p>
      </div>
    )}
  </div>
</Layout>
