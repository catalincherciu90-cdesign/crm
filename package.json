{
  "name": "crm",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "CRM pentru oferte catre clienti si gestiune stocuri (Cloudflare + Astro + D1)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply crm-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply crm-db --remote",
    "db:seed:local": "wrangler d1 execute crm-db --local --file=./migrations/seed.sql",
    "db:seed:remote": "wrangler d1 execute crm-db --remote --file=./migrations/seed.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.5.0",
    "@astrojs/react": "^4.2.0",
    "astro": "^5.7.0",
    "drizzle-orm": "^0.44.0",
    "fast-xml-parser": "^5.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250414.0 || ^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.14.0"
  }
}
