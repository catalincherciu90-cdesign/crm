---
import { eq } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import ProductForm from '@/components/ProductForm.astro';
import { getDb } from '@/db';
import { products } from '@/db/schema';

export const prerender = false;

const id = Number(Astro.params.id);
const db = getDb(Astro.locals.runtime.env.DB);
const [product] = await db.select().from(products).where(eq(products.id, id));

if (!product) return Astro.redirect('/products');

const images = product.images ? product.images.split('#').filter(Boolean) : [];
const files = product.files ? product.files.split('#').filter(Boolean) : [];
const fileName = (u: string) => decodeURIComponent(u.split('/').pop() || u);
---

<Layout title={`Editează ${product.name}`}>
  <div class="mx-auto max-w-2xl">
    <a href="/products" class="text-sm text-indigo-600 hover:underline">← Produse</a>
    <h1 class="mt-2 mb-6 text-2xl font-bold text-slate-900">Editează produs</h1>

    {(images.length > 0 || files.length > 0) && (
      <div class="mb-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        {images.length > 0 && (
          <div class="mb-4">
            <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-400">Poze produs ({images.length})</h2>
            <div class="flex flex-wrap gap-3">
              {images.map((src) => (
                <a href={src} target="_blank" rel="noopener">
                  <img src={src} alt={product.name} loading="lazy" class="h-24 w-24 rounded-lg border border-slate-200 bg-white object-contain transition hover:border-indigo-400" />
                </a>
              ))}
            </div>
          </div>
        )}
        {files.length > 0 && (
          <div>
            <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-400">Fișe tehnice ({files.length})</h2>
            <ul class="space-y-1">
              {files.map((href) => (
                <li>
                  <a href={href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-indigo-600 hover:underline">
                    📄 {fileName(href)}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <ProductForm product={product} />
    </div>
  </div>
</Layout>
