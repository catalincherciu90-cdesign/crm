---
import { asc, eq, sql } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/db';
import { agents, clients } from '@/db/schema';
import { formatMoney } from '@/lib/money';

export const prerender = false;

const db = getDb(Astro.locals.runtime.env.DB);

const rows = await db
  .select({
    id: agents.id,
    name: agents.name,
    email: agents.email,
    active: agents.active,
    target: agents.monthlyTarget,
    clientCount: sql<number>`count(${clients.id})`,
  })
  .from(agents)
  .leftJoin(clients, eq(clients.agentId, agents.id))
  .groupBy(agents.id)
  .orderBy(asc(agents.name));

// Realizat luna curenta (oferte acceptate) pe agent
const ach = (await db.all(sql`
  SELECT c.agent_id AS aid, coalesce(sum(o.total), 0) AS achieved
  FROM offers o JOIN clients c ON c.id = o.client_id
  WHERE o.status = 'accepted' AND o.issue_date >= date('now','start of month')
  GROUP BY c.agent_id
`)) as { aid: number; achieved: number }[];
const achByAgent = new Map(ach.map((r) => [r.aid, r.achieved]));

const now = new Date();
const luna = now.toLocaleDateString('ro-RO', { month: 'long', year: 'numeric' });

const withProgress = rows.map((a) => {
  const achieved = achByAgent.get(a.id) ?? 0;
  const pct = a.target > 0 ? Math.round((achieved / a.target) * 100) : 0;
  return { ...a, achieved, pct };
});
const totalTarget = withProgress.reduce((s, a) => s + a.target, 0);
const totalAchieved = withProgress.reduce((s, a) => s + a.achieved, 0);
const totalPct = totalTarget > 0 ? Math.round((totalAchieved / totalTarget) * 100) : 0;

function barColor(pct: number) {
  if (pct >= 100) return 'bg-green-500';
  if (pct >= 60) return 'bg-amber-500';
  return 'bg-indigo-500';
}
---

<Layout title="Agenți">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Agenți de vânzări</h1>
      <p class="text-sm text-slate-500">{rows.length} agenți · target &amp; realizat pentru <span class="capitalize">{luna}</span>.</p>
    </div>
    <a href="/agents/new" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">+ Agent nou</a>
  </div>

  <!-- Sumar echipa (masterul vede tot) -->
  <div class="mb-6 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex items-end justify-between">
      <div>
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-400">Target echipă · {luna}</div>
        <div class="mt-1 text-2xl font-bold text-slate-900">{formatMoney(totalAchieved)} <span class="text-base font-normal text-slate-400">/ {formatMoney(totalTarget)}</span></div>
      </div>
      <div class="text-right text-2xl font-bold text-indigo-700">{totalPct}%</div>
    </div>
    <div class="mt-3 h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
      <div class={`h-full ${barColor(totalPct)} transition-all`} style={`width:${Math.min(totalPct, 100)}%`}></div>
    </div>
  </div>

  <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
    {rows.length === 0 ? (
      <p class="p-8 text-center text-sm text-slate-400">
        Niciun agent încă. Adaugă unul sau importă clienți din ERP — agenții se creează automat.
      </p>
    ) : (
      <table class="w-full text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">Agent</th>
            <th class="px-4 py-3 text-right">Clienți</th>
            <th class="px-4 py-3 text-right">Target lunar</th>
            <th class="px-4 py-3 text-right">Realizat (luna)</th>
            <th class="px-4 py-3 w-48">Progres</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {withProgress.map((a) => (
            <tr class="cursor-pointer hover:bg-slate-50" onclick={`location.href='/agents/${a.id}'`}>
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900">{a.name}</div>
                {!a.active && <span class="text-[11px] text-slate-400">inactiv</span>}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/clients?agent=${a.id}`} class="text-indigo-600 hover:underline" onclick="event.stopPropagation()">{a.clientCount}</a>
              </td>
              <td class="px-4 py-3 text-right text-slate-700">{a.target > 0 ? formatMoney(a.target) : '—'}</td>
              <td class="px-4 py-3 text-right font-medium text-slate-900">{formatMoney(a.achieved)}</td>
              <td class="px-4 py-3">
                {a.target > 0 ? (
                  <div>
                    <div class="mb-1 text-[11px] text-slate-500">{a.pct}%</div>
                    <div class="h-2 w-full overflow-hidden rounded-full bg-slate-100">
                      <div class={`h-full ${barColor(a.pct)}`} style={`width:${Math.min(a.pct, 100)}%`}></div>
                    </div>
                  </div>
                ) : (
                  <span class="text-xs text-slate-400">fără target</span>
                )}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/agents/${a.id}`} class="text-indigo-600 hover:underline">Detalii</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
  <p class="mt-3 text-xs text-slate-400">„Realizat" = totalul ofertelor cu status <strong>acceptată</strong> din luna curentă.</p>
</Layout>
