---
import Layout from '@/layouts/Layout.astro';
import FeedImporter from '@/components/FeedImporter.tsx';
import ImageImporter from '@/components/ImageImporter.tsx';
import { getDb } from '@/db';
import { feedSources } from '@/db/schema';

export const prerender = false;

const db = getDb(Astro.locals.runtime.env.DB);
const sources = await db.select().from(feedSources);
---

<Layout title="Import feed">
  <div class="mb-6">
    <a href="/products" class="text-sm text-indigo-600 hover:underline">← Produse</a>
    <h1 class="mt-2 text-2xl font-bold text-slate-900">Import product feed</h1>
    <p class="text-sm text-slate-500">
      Sincronizează catalogul de produse și stocurile dintr-un feed XML. Produsele se actualizează după SKU (upsert).
    </p>
  </div>

  {sources.length > 0 && (
    <div class="mb-6 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-400">Surse configurate</h2>
      <ul class="space-y-1 text-sm">
        {sources.map((s) => (
          <li class="flex flex-wrap items-center justify-between gap-2">
            <span class="font-medium text-slate-800">{s.name}</span>
            <span class="text-xs text-slate-400">
              {s.lastSyncAt ? `ultima sincronizare: ${s.lastSyncAt} · ${s.lastCount} produse` : 'nesincronizat încă'}
            </span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <section>
    <h2 class="mb-1 text-lg font-semibold text-slate-900">1. Produse &amp; prețuri &amp; stoc (XML)</h2>
    <p class="mb-3 text-sm text-slate-500">Catalog complet: nume, prețuri A/B, stoc, categorii, fișe tehnice.</p>
    <FeedImporter client:load sources={sources} />
  </section>

  <hr class="my-8 border-slate-200" />

  <section>
    <h2 class="mb-1 text-lg font-semibold text-slate-900">2. Poze produse (CSV)</h2>
    <p class="mb-3 text-sm text-slate-500">
      Feed separat de poze (de pe spotvisionelectric.ro), legat la produse după SKU. Actualizează doar pozele.
    </p>
    <ImageImporter client:only="react" />
  </section>
</Layout>
