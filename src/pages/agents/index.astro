---
import { asc, eq, sql } from 'drizzle-orm';
import Layout from '@/layouts/Layout.astro';
import { getDb } from '@/db';
import { agents, clients } from '@/db/schema';

export const prerender = false;

const db = getDb(Astro.locals.runtime.env.DB);
const rows = await db
  .select({
    id: agents.id,
    name: agents.name,
    email: agents.email,
    phone: agents.phone,
    active: agents.active,
    clientCount: sql<number>`count(${clients.id})`,
  })
  .from(agents)
  .leftJoin(clients, eq(clients.agentId, agents.id))
  .groupBy(agents.id)
  .orderBy(asc(agents.name));
---

<Layout title="Agenți">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">Agenți de vânzări</h1>
      <p class="text-sm text-slate-500">{rows.length} agenți.</p>
    </div>
    <a href="/agents/new" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">+ Agent nou</a>
  </div>

  <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    {rows.length === 0 ? (
      <p class="p-8 text-center text-sm text-slate-400">
        Niciun agent încă. Adaugă unul manual sau importă clienți din ERP — agenții din coloana AGENT se creează automat.
      </p>
    ) : (
      <table class="w-full text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">Nume</th>
            <th class="px-4 py-3">Contact</th>
            <th class="px-4 py-3 text-right">Clienți alocați</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {rows.map((a) => (
            <tr class="cursor-pointer hover:bg-slate-50" onclick={`location.href='/agents/${a.id}'`}>
              <td class="px-4 py-3 font-medium text-slate-900">{a.name}</td>
              <td class="px-4 py-3 text-slate-600">
                {a.email ?? '—'}
                {a.phone && <span class="block text-xs text-slate-400">{a.phone}</span>}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/clients?agent=${a.id}`} class="font-semibold text-indigo-600 hover:underline" onclick="event.stopPropagation()">
                  {a.clientCount}
                </a>
              </td>
              <td class="px-4 py-3">
                {a.active
                  ? <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-[11px] font-medium text-green-700">Activ</span>
                  : <span class="inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[11px] font-medium text-slate-500">Inactiv</span>}
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/agents/${a.id}`} class="text-indigo-600 hover:underline">Editează</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</Layout>
